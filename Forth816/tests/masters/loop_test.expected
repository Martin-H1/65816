\ RECURSE - factorial
 ok 
: FACTORIAL DUP 1 > IF DUP 1- RECURSE * THEN ;
 ok 
T{ 5 FACTORIAL -> 120 }T
 ok 
T{ 0 FACTORIAL -> 0 }T
 ok 
T{ 1 FACTORIAL -> 1 }T
 ok 

