\ ttester.fs - John Hayes's test framework (no floating point)
 ok 
\ Adapted for Forth816
 ok 

 ok 
MARKER RESET-TEST   \ restore dictionary to this point after each test
 ok 

 ok 
\ Clear the parameter stack
 ok 
: CLEAR-STACK BEGIN DEPTH WHILE DROP REPEAT ;
 ok 
CLEAR-STACK
 ok 

 ok 
DECIMAL
 ok 

 ok 
VARIABLE ACTUAL-DEPTH
 ok 
CREATE ACTUAL-RESULTS 32 CELLS ALLOT
 ok 
VARIABLE START-DEPTH
 ok 
VARIABLE XCURSOR
 ok 
VARIABLE ERROR-XT
 ok 

 ok 
: ERROR ( c-addr u -- )
    TYPE CR ;
 ok 

 ok 
' ERROR ERROR-XT !  \ default error handler
 ok 

 ok 
: T{
    DEPTH START-DEPTH ! ;
 ok 

 ok 
: ->
    DEPTH DUP ACTUAL-DEPTH !
    START-DEPTH @ - DUP 0< IF
        S" WRONG NUMBER OF RESULTS: " ERROR
    THEN
    0 ?DO
        ACTUAL-RESULTS I CELLS + !
    LOOP ;
 ok 

 ok 
: }T
    DEPTH START-DEPTH @ - ACTUAL-DEPTH @ <> IF
        S" WRONG NUMBER OF RESULTS: " TYPE CR
    ELSE
        ACTUAL-DEPTH @ 0 ?DO
            ACTUAL-RESULTS I CELLS + @ <> IF
                S" INCORRECT RESULT: " TYPE CR
            THEN
        LOOP
    THEN ;
 ok 

 ok 
: DONE ." ###DONE###" CR RESET-TEST ;
 ok 
\ double_test.fs - Double number regression tests
 ok 

 ok 
\ 2LIT and basic double literals
 ok 
T{ 0. -> 0 0 }T
 ok 
T{ 1234. -> 1234 0 }T
 ok 
T{ -1. -> -1 -1 }T
 ok 
T{ 100000. -> 34464 1 }T  \ $186A0
 ok 

 ok 
\ >NUMBER
 ok 
T{ 0 0 S" 0" >NUMBER 2DROP -> 0 0 }T
 ok 
T{ 0 0 S" 1234" >NUMBER 2DROP -> 1234 0 }T
 ok 
T{ 0 0 S" 100000" >NUMBER 2DROP -> 34464 1 }T
 ok 

 ok 
\ D+
 ok 
T{ 1. 2. D+ -> 3 0 }T
 ok 
T{ -1. 1. D+ -> 0 0 }T
 ok 
T{ 100000. 100000. D+ -> 3392 3 }T  \ 200000 = $30D40
 ok 

 ok 
\ D-
 ok 
T{ 3. 2. D- -> 1 0 }T
 ok 
T{ 0. 1. D- -> -1 -1 }T
 ok 

 ok 
\ DNEGATE
 ok 
T{ 1. DNEGATE -> -1 -1 }T
 ok 
T{ -1. DNEGATE -> 1 0 }T
 ok 
T{ 0. DNEGATE -> 0 0 }T
 ok 

 ok 
\ DABS
 ok 
T{ -1. DABS -> 1 0 }T
 ok 
T{ 1. DABS -> 1 0 }T
 ok 

 ok 
\ D=
 ok 
T{ 1. 1. D= -> -1 }T
 ok 
T{ 1. 2. D= -> 0 }T
 ok 
T{ 100000. 100000. D= -> -1 }T
 ok 

 ok 
\ D
 ok 
T{ 1. 2. D< -> -1 }T
 ok 
T{ 2. 1. D< -> 0 }T
 ok 
T{ -1. 0. D< -> -1 }T
 ok 

 ok 
\ DU
 ok 
T{ 1. 2. DU< -> -1 }T
 ok 
T{ 2. 1. DU< -> 0 }T
 ok 

 ok 
\ D>S
 ok 
T{ 1234. D>S -> 1234 }T
 ok 

 ok 
\ S>D
 ok 
T{ 1234 S>D -> 1234 0 }T
 ok 
T{ -1 S>D -> -1 -1 }T
 ok 

 ok 
\ M+
 ok 
T{ 1. 2 M+ -> 3 0 }T
 ok 
T{ -1. 1 M+ -> 0 0 }T
 ok 

 ok 
DONE
###DONE###