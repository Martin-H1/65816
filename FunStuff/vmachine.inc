;------------------------------------------------------------------------------
; Platform specific initialization
;------------------------------------------------------------------------------

; Conditionally import virtual machine functions in consuming modules.
.ifndef __vmachine_s__
.import vm_cputs
.import vm_getch
.import vm_putahex
.import vm_putchex
.import vm_putch
.endif

;------------------------------------------------------------------------------
; PUBLIC / ENDPUBLIC - Export a subroutine as a global symbol
;
; Usage:
;   PUBLIC my_function
;       ... code ...
;   ENDPUBLIC
;------------------------------------------------------------------------------
.macro  PUBLIC function_name
        .export function_name
        .proc   function_name
	.A16
	.I16
.endmacro

.macro  ENDPUBLIC
        .endproc
.endmacro


;==============================================================================
; Stack operations
;==============================================================================

;------------------------------------------------------------------------------
; DROP - Drops the top of stack (TOS)
;------------------------------------------------------------------------------
.macro	DROP
	INX
	INX
.endmacro

;------------------------------------------------------------------------------
; DUP - Duplicates the top of stack (TOS)
;------------------------------------------------------------------------------
.macro	DUP
	LDA	0,X
	PUSH
.endmacro

;------------------------------------------------------------------------------
; PUSH - Push value in A onto parameter stack
;------------------------------------------------------------------------------
.macro  PUSH
        DEX
        DEX
        STA	0,X
.endmacro

;------------------------------------------------------------------------------
; PUSHI - Push immediate onto the stack
;------------------------------------------------------------------------------
.macro	PUSHI arg
	LDA	#arg
	PUSH
.endmacro

;------------------------------------------------------------------------------
; POP - Pop top of parameter stack into A
;------------------------------------------------------------------------------
.macro  POP
        LDA	0,X
        INX
        INX
.endmacro

;------------------------------------------------------------------------------
; SWAP - exchanges top two stack elements ( a b - b a )
;------------------------------------------------------------------------------
.macro  SWAP
        LDA	0,X
        PHA
        LDA	2,X
	STA	0,X
	PLA
	STA	2,X
.endmacro

;==============================================================================
; Arithmetic
;==============================================================================

;------------------------------------------------------------------------------
; PLUS - Adds the first two cells on the data stack
;------------------------------------------------------------------------------
.macro  PLUS
        POP
        CLC
	ADD
.endmacro

;------------------------------------------------------------------------------
; MINUS - Subtracts the first two cells on the data stack
;------------------------------------------------------------------------------
.macro	SUB
	LDA	2,X
	SEC
	SBC	0,X
	DROP
	DROP
.endmacro

;------------------------------------------------------------------------------
; NEGATE - Perform two's compliment of TOS
;------------------------------------------------------------------------------
.macro	NEGATE
	PEEK
	EOR	#$FFFF
	INC
	PUT
.endmacro


;==============================================================================
; Flow control
;==============================================================================

;------------------------------------------------------------------------------
; BRANCHZ - Branch to argument if Z bit is set.
;------------------------------------------------------------------------------
.macro  BRANCHZ arg
	BEQ	arg
.endmacro

;------------------------------------------------------------------------------
; BRANCHNZ - Branch to argument if Z bit is not set.
;------------------------------------------------------------------------------
.macro  BRANCHNZ arg
	BNE	arg
.endmacro

;------------------------------------------------------------------------------
; BRANCH - Branch unconditionally to argument
;------------------------------------------------------------------------------
.macro  BRANCH arg
	JMP	arg
.endmacro

;------------------------------------------------------------------------------
; CALL - Call a subroutine
;------------------------------------------------------------------------------
.macro  CALL arg
	JSR	arg
.endmacro

;------------------------------------------------------------------------------
; RETURN - Return for a subroutine
;------------------------------------------------------------------------------
.macro  RETURN
	RTS
.endmacro

;------------------------------------------------------------------------------
; HALT - Return to monitor
;------------------------------------------------------------------------------
.macro  HALT
	RTL
.endmacro


;==============================================================================
; I/O functions
;==============================================================================

;------------------------------------------------------------------------------
; DOT - pops TOS and prints to console.
;------------------------------------------------------------------------------
.macro  DOT
	POP
	JSR	vm_putchex
.endmacro

;------------------------------------------------------------------------------
; PRINTCR - prints a CR to the console.
;------------------------------------------------------------------------------
.macro  PRINTCR
	LDA	#$0D
	JSR	vm_putch
	LDA	#$0A
	JSR	vm_putch
.endmacro

;------------------------------------------------------------------------------
; CPUTS - prints text to console.
;------------------------------------------------------------------------------
.macro  CPUTS arg
	.local @text
	.local @skip
	LDA	#@text
	JSR	vm_cputs
	BRA	@skip
@text:	.asciiz arg
@skip:
.endmacro
