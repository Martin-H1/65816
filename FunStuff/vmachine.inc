;------------------------------------------------------------------------------
; Platform specific initialization
;------------------------------------------------------------------------------

; Conditionally import virtual machine functions in consuming modules.
.ifndef __vmachine_s__
.import vm_cputs
.import vm_getch
.import vm_putahex
.import vm_putchex
.import vm_putch
.import vm_stod
.import vm_wmuls
.import vm_wdivs
.endif

; Common constants

; Integer constants (based on C's limits.h)
INT_MIN         = $8000
INT_MAX         = $7FFF
MINUS_ONE       = $FFFF
UINT_MAX        = $FFFF

TOS		= 0
NOS		= 2

;------------------------------------------------------------------------------
; PUBLIC / ENDPUBLIC - Export a subroutine as a global symbol
;
; Usage:
;   PUBLIC my_function
;       ... code ...
;   ENDPUBLIC
;------------------------------------------------------------------------------
.macro  PUBLIC function_name
        .export function_name
        .proc   function_name
	.A16
	.I16
.endmacro

.macro  ENDPUBLIC
        .endproc
.endmacro


;==============================================================================
; Stack operations
;==============================================================================

;------------------------------------------------------------------------------
; DROP - Drops the top of stack (TOS)
;------------------------------------------------------------------------------
.macro	DROP
	INX
	INX
.endmacro

;------------------------------------------------------------------------------
; DUP - Duplicates the top of stack (TOS)
;------------------------------------------------------------------------------
.macro	DUP
	LDA	TOS,X
	DEX
	DEX
	STA	TOS,X
.endmacro

;------------------------------------------------------------------------------
; NIP - Replace NOS with TOS and drop a cell
;------------------------------------------------------------------------------
.macro  NIP
	LDA	TOS,X
	DROP
	STA	TOS,X
.endmacro

;------------------------------------------------------------------------------
; PUSH - Push value at address arg onto parameter stack
;------------------------------------------------------------------------------
.macro  PUSH addr
	LDA	addr
	DEX
	DEX
	STA	TOS,X
.endmacro

;------------------------------------------------------------------------------
; PUSHI - Push immediate onto the stack
;------------------------------------------------------------------------------
.macro	PUSHI arg
	LDA	#arg
	DEX
	DEX
	STA	TOS,X
.endmacro

;------------------------------------------------------------------------------
; POP - Pop top of parameter stack to address
;------------------------------------------------------------------------------
.macro  POP addr
	LDA	TOS,X
	STA	addr
	INX
	INX
.endmacro

;------------------------------------------------------------------------------
; ROT - ( a b c -- b c a )
;------------------------------------------------------------------------------
.macro	ROT
	LDA	4,X		; a (bottom)
	PHA
	LDA	NOS,X		; b
	STA	4,X		; bottom slot = b
	LDA	TOS,X		; c (TOS)
	STA	NOS,X		; middle slot = c
	PLA
	STA	TOS,X		; TOS = a
.endmacro

;------------------------------------------------------------------------------
; SWAP - exchanges top two stack elements ( a b - b a )
;------------------------------------------------------------------------------
.macro  SWAP
        LDA	TOS,X
        PHA
        LDA	NOS,X
	STA	TOS,X
	PLA
	STA	NOS,X
.endmacro

;------------------------------------------------------------------------------
; TUCK - ( a b - b a b )
;------------------------------------------------------------------------------
.macro  TUCK
	DUP				; TOS = b
	LDA	4,X			; a
	STA	NOS,X			; NOS = a
	LDA	TOS,X			; b
	STA	4,X			; Slot below a = b
.endmacro

;==============================================================================
; Memory operations
;==============================================================================

;------------------------------------------------------------------------------
; BFETCH - Replace TOS with the byte value at that address
;------------------------------------------------------------------------------
.macro  BFETCH
	JSR	vm_bfetch	; fetch 8-bit value
.endmacro

;------------------------------------------------------------------------------
; BSTORE - stores NOS byte value at TOS address and drops both cells.
;------------------------------------------------------------------------------
.macro  BSTORE
	JSR	vm_bstore	; fetch 8-bit value
.endmacro

;------------------------------------------------------------------------------
; WFETCH - Replace TOS with value at that address
;------------------------------------------------------------------------------
.macro  WFETCH
	LDY	TOS,X		; addr
	LDA	0,Y		; fetch 16-bit value
	STA	TOS,X
.endmacro

;------------------------------------------------------------------------------
; WSTORE - stores NOS value at TOS address and drops both cells.
;------------------------------------------------------------------------------
.macro  WSTORE
	LDY	TOS,X
	LDA	NOS,X
	STA	0,Y
	DROP
	DROP
.endmacro

;------------------------------------------------------------------------------
; WORD - allocates a word of storage and initializes it with arg
;------------------------------------------------------------------------------
.macro WORD arg
       .word arg
.endmacro

;==============================================================================
; Comparison operations
;==============================================================================

;------------------------------------------------------------------------------
; TOSZERO - Nondestructively compares TOS with zero.
;------------------------------------------------------------------------------
.macro  TOSZERO
	LDA	TOS,X
	CMP	#0
.endmacro

;==============================================================================
; Logical operations
;==============================================================================

;------------------------------------------------------------------------------
; ANDS - ANDs the NOS and TOS cells on the data stack
;------------------------------------------------------------------------------
.macro  ANDNT
        LDA	TOS,X
	DROP
        AND	TOS,X
	STA	TOS,X
.endmacro

;------------------------------------------------------------------------------
; ORS - ORs the NOS and TOS cells on the data stack
;------------------------------------------------------------------------------
.macro  ORS
        LDA	TOS,X
	DROP
        ORA	TOS,X
	STA	TOS,X
.endmacro

;------------------------------------------------------------------------------
; NOTS - Inverts bits of TOS
;------------------------------------------------------------------------------
.macro	NOTS
	LDA	TOS,X
	EOR	#$FFFF
	STA	TOS,X
.endmacro

;------------------------------------------------------------------------------
; XORS - XORs the NOS and TOS on the data stack
;------------------------------------------------------------------------------
.macro  XORS
        LDA	TOS,X
	DROP
        EOR	TOS,X
	STA	TOS,X
.endmacro


;==============================================================================
; Arithmetic
;==============================================================================

;------------------------------------------------------------------------------
; ADDS - Adds the first two cells on the data stack
;------------------------------------------------------------------------------
.macro  ADDS
        LDA	TOS,X
	DROP
	CLC
	ADC	TOS,X
	STA	TOS,X
.endmacro

;------------------------------------------------------------------------------
; DECTOS - Decrements TOS
;------------------------------------------------------------------------------
.macro	DECTOS
	DEC	TOS,X
.endmacro

;------------------------------------------------------------------------------
; INCTOS - Increments TOS
;------------------------------------------------------------------------------
.macro	INCTOS
	INC	TOS,X
.endmacro

;------------------------------------------------------------------------------
; NEGATES - Perform two's compliment of TOS
;------------------------------------------------------------------------------
.macro	NEGATES
	NOTS
	INCTOS
.endmacro

;------------------------------------------------------------------------------
; SUBS - Subtracts the first two cells on the data stack
;------------------------------------------------------------------------------
.macro	SUBS
	LDA	NOS,X
	SEC
	SBC	TOS,X
	DROP
	DROP
.endmacro

;------------------------------------------------------------------------------
; STOD - sign extend a single to double
;------------------------------------------------------------------------------
.macro	STOD
	JSR	vm_stod
.endmacro

;------------------------------------------------------------------------------
; WMULS - multiply two words on stack and push result
;------------------------------------------------------------------------------
.macro	WMULS
	JSR	vm_wmuls
.endmacro

;------------------------------------------------------------------------------
; WDIVS - divide two words on stack
;------------------------------------------------------------------------------
.macro	WDIVS
	JSR	vm_wdivs
.endmacro


;==============================================================================
; Bit shifts
;==============================================================================

;------------------------------------------------------------------------------
; ASLS - Arithmetic left shift TOS
;------------------------------------------------------------------------------
.macro	ASLS
	ASL	TOS,X
.endmacro

;------------------------------------------------------------------------------
; LSRS - Logical right shift TOS
;------------------------------------------------------------------------------
.macro	LSRS
	LSR	TOS,X
.endmacro

;------------------------------------------------------------------------------
; ROLS - Rotagte left the TOS
;------------------------------------------------------------------------------
.macro	ROLS
	ROL	TOS,X
.endmacro

;------------------------------------------------------------------------------
; RORS - Rotate right the TOS
;------------------------------------------------------------------------------
.macro	RORS
	ROR	TOS,X
.endmacro

;==============================================================================
; Flow control
;==============================================================================

;------------------------------------------------------------------------------
; HALT - Return to monitor
;------------------------------------------------------------------------------
.macro  HALT
	RTL
.endmacro


;==============================================================================
; I/O functions
;==============================================================================

;------------------------------------------------------------------------------
; PRINTTOS - pops TOS and prints to console.
;------------------------------------------------------------------------------
.macro	PRINTTOS
	LDA	TOS,X
	DROP
	JSR	vm_putchex
.endmacro

;------------------------------------------------------------------------------
; PRINTCR - prints a CR to the console.
;------------------------------------------------------------------------------
.macro	PRINTCR
	LDA	#$0D
	JSR	vm_putch
	LDA	#$0A
	JSR	vm_putch
.endmacro

;------------------------------------------------------------------------------
; CPUTS - prints text to console.
;------------------------------------------------------------------------------
.macro	CPUTS arg
	.local @text
	.local @skip
	LDA	#@text
	JSR	vm_cputs
	BRA	@skip
@text:	.asciiz arg
@skip:
.endmacro
