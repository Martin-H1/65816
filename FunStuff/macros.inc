;------------------------------------------------------------------------------
; Platform specific initialization
;------------------------------------------------------------------------------
; Control bits for REP and SEP
MEM16   = $20                   ; Accumulator width bit
IND16   = $10                   ; Index register width bit

.macro	INIT
	REP	#(MEM16|IND16)	; All registers = 16-bit
	.A16
	.I16
	LDX	#$03FF		; Parameter stack pointer
.endmacro

;==============================================================================
; Stack operations
;==============================================================================

;------------------------------------------------------------------------------
; DROP - Drops the top of stack (TOS)
;------------------------------------------------------------------------------
.macro	DROP
	INX
	INX
.endmacro

;------------------------------------------------------------------------------
; DUP - Duplicates the top of stack (TOS)
;------------------------------------------------------------------------------
.macro	DUP
	LDA	0,X
	PUSH
.endmacro

;------------------------------------------------------------------------------
; PUSH - Push value in A onto parameter stack
;------------------------------------------------------------------------------
.macro  PUSH
        DEX
        DEX
        STA	0,X
.endmacro

;------------------------------------------------------------------------------
; PUSHI - Push immediate onto the stack
;------------------------------------------------------------------------------
.macro	PUSHI arg
	LDA	#arg
	PUSH
.endmacro

;------------------------------------------------------------------------------
; POP - Pop top of parameter stack into A
;------------------------------------------------------------------------------
.macro  POP
        LDA	0,X
        INX
        INX
.endmacro

;------------------------------------------------------------------------------
; SWAP - exchanges top two stack elements ( a b - b a )
;------------------------------------------------------------------------------
.macro  SWAP
        LDA	0,X
        PHA
        LDA	2,X
	STA	0,X
	PLA
	STA	2,X
.endmacro

;==============================================================================
; Arithmetic
;==============================================================================

;------------------------------------------------------------------------------
; PLUS - Adds the first two cells on the data stack
;------------------------------------------------------------------------------
.macro  PLUS
        POP
        CLC
	ADD
.endmacro

;------------------------------------------------------------------------------
; MINUS - Subtracts the first two cells on the data stack
;------------------------------------------------------------------------------
.macro	SUB
	LDA	2,X
	SEC
	SBC	0,X
	DROP
	DROP
.endmacro


;==============================================================================
; Flow control
;==============================================================================

;------------------------------------------------------------------------------
; ZBRANCH - Branch to argument if Z bit is set.
;------------------------------------------------------------------------------
.macro  ZBRANCH arg
	BEQ	arg
.endmacro

;------------------------------------------------------------------------------
; BRANCH - Branch unconditionally to argument
;------------------------------------------------------------------------------
.macro  BRANCH arg
	JMP	arg
.endmacro

;------------------------------------------------------------------------------
; HALT - Return to monitor
;------------------------------------------------------------------------------
.macro  HALT
	RTL
.endmacro


;==============================================================================
; I/O functions
;==============================================================================

;------------------------------------------------------------------------------
; DOT - pops TOS and prints to console.
;------------------------------------------------------------------------------
.macro  DOT
	NOP
.endmacro

;------------------------------------------------------------------------------
; TYPE - prints text to console.
;------------------------------------------------------------------------------
.macro  TYPE arg
.scope
	BRA	@skip
@text:	.asciiz arg
@skip:
.endscope
.endmacro

